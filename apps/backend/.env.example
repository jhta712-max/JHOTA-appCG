# ============================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# BASE DE DATOS (PostgreSQL)
# Usar estos valores con docker-compose (desarrollo local)
# ============================================================
DATABASE_URL="postgresql://gastos_user:gastos_pass_local@localhost:5432/gastos_proyectos"

# ============================================================
# JWT (JSON Web Tokens)
# IMPORTANTE: Cambiar JWT_SECRET en producción por un valor
# aleatorio seguro de al menos 64 caracteres
# ============================================================
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_AL_MENOS_64_CARACTERES_EN_PRODUCCION"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================================
# CORS - URL del frontend
# ============================================================
FRONTEND_URL=http://localhost:5173

# ============================================================
# ALMACENAMIENTO DE ARCHIVOS
# STORAGE_TYPE: 'local' para desarrollo, 's3' para producción
# ============================================================
STORAGE_TYPE=local
UPLOAD_PATH=./uploads
UPLOAD_MAX_SIZE_MB=10

# ============================================================
# AWS S3 (Solo para producción - STORAGE_TYPE=s3)
# ============================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=us-east-1
# AWS_ENDPOINT=   # Para S3-compatible como Cloudflare R2

# ============================================================
# EMAIL (Gmail con App Password)
# Para obtener el App Password de Gmail:
# 1. Ve a myaccount.google.com/security
# 2. Activa verificación en 2 pasos
# 3. Busca "Contraseñas de aplicaciones"
# 4. Crea una para "Correo - Windows"
# ============================================================
GMAIL_USER=tu.correo@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=info

# ============================================================
# ANTHROPIC API — OCR inteligente de facturas
# Obtén tu clave en: https://console.anthropic.com/
# Sin esta clave el botón "Analizar con IA" no estará disponible
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================
# MONITOREO — Notificaciones de Sistema
# ============================================================

# URL pública de la aplicación (usada en los emails)
APP_URL=https://tu-app.railway.app

# Activar monitoring jobs en desarrollo (en producción se activan automáticamente)
ENABLE_MONITORING=false

# Zona horaria para los cron jobs (reportes diarios/semanales)
TZ=America/Santo_Domingo

# Umbral de errores para alerta (N errores en 10 minutos dispara notificación)
MONITOR_ERROR_THRESHOLD=15

# ── Email de notificaciones ────────────────────────────────
# Servidor SMTP (Gmail recomendado con App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu.correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx   # App Password de Gmail

# Remitente (puede ser igual a SMTP_USER)
NOTIFY_EMAIL_FROM=SERVINGMI Monitoreo <tu.correo@gmail.com>

# Destinatarios (separados por coma si son varios)
NOTIFY_EMAIL_TO=jhta.712@gmail.com,otro@email.com

# ── WhatsApp vía Twilio ────────────────────────────────────
# Regístrate en: https://console.twilio.com/
# WhatsApp sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Número origen de Twilio (sandbox: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Destinatario(s) WhatsApp (formato: whatsapp:+18095551234 , separados por coma)
NOTIFY_WHATSAPP_TO=whatsapp:+18091234567
