// ============================================================
// PRISMA SCHEMA — Sistema de Gastos por Proyectos
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ROLES
// ============================================================
model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50) // 'admin' | 'supervisor' | 'operator'
  description String?  @db.Text
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  users       User[]
  invitations Invitation[]

  @@map("roles")
}

// ============================================================
// USUARIOS
// ============================================================
model User {
  id            String    @id @default(uuid()) @db.Uuid
  roleId        Int       @map("role_id")
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  password      String    @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  avatarUrl     String?   @map("avatar_url") @db.VarChar(500)
  isActive      Boolean   @default(true) @map("is_active")
  whatsappOptIn Boolean   @default(false) @map("whatsapp_opt_in")
  notifTypes    String[]  @default([]) @map("notif_types")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  role                      Role                   @relation(fields: [roleId], references: [id])
  notifications             Notification[]
  notificationContacts      NotificationContact[]  @relation("ContactCreatedBy")
  projects                  Project[]              @relation("ProjectCreatedBy")
  expenses                  Expense[]              @relation("ExpenseRegisteredBy")
  voidedExpenses            Expense[]              @relation("ExpenseVoidedBy")
  approvedExpenses          Expense[]              @relation("ExpenseApprovedBy")
  rejectedExpenses          Expense[]              @relation("ExpenseRejectedBy")
  attachments               Attachment[]
  auditLogs                 AuditLog[]
  refreshTokens             RefreshToken[]
  invitationsSent           Invitation[]           @relation("InvitedBy")
  addendums                 ProjectAddendum[]      @relation("AddendumCreatedBy")
  cubicaciones              ProjectCubicacion[]    @relation("CubicacionCreatedBy")
  projectAssignments        ProjectAssignment[]    @relation("AssignedToProject")
  assignmentsMade           ProjectAssignment[]    @relation("AssignedByUser")
  payrollsCreated           Payroll[]              @relation("PayrollCreatedBy")
  payrollsApproved          Payroll[]              @relation("PayrollApprovedBy")
  payrollsVoided            Payroll[]              @relation("PayrollVoidedBy")
  quotationsCreated         Quotation[]            @relation("QuotationCreatedBy")
  quotationPayments         QuotationPayment[]     @relation("QuotationPaymentCreatedBy")
  quotationLinks            QuotationExpenseLink[] @relation("QuotationLinkCreatedBy")
  quotationAttachments      QuotationAttachment[]
  paymentOrdersCreated      PaymentOrder[]         @relation("PaymentOrderCreatedBy")
  paymentOrdersPaid         PaymentOrder[]         @relation("PaymentOrderPaidBy")
  paymentOrdersExchangeValidated PaymentOrder[]    @relation("PaymentOrderExchangeValidatedBy")
  officeExpenses            OfficeExpense[]        @relation("OfficeExpenseCreatedBy")
  suppliersCreated          Supplier[]             @relation("SupplierCreatedBy")
  contratosAjustadosCreated      ContratoAjustado[]       @relation("ContratoAjustadoCreatedBy")
  contratosAjustadosUpdated      ContratoAjustado[]       @relation("ContratoAjustadoUpdatedBy")
  contratoAdendas                ContratoAjustadoAdenda[] @relation("ContratoAdendaCreatedBy")
  contratoAjustadoPagosCreadoPor ContratoAjustadoPago[]   @relation("ContratoAjustadoPagoCreadoPor")
  ocrJobs                        OcrJob[]
  whatsAppConversations          WhatsAppConversation[] @relation("WhatsAppConversationUser")
  creditLinesCreated    SupplierCreditLine[]    @relation("CreditLineCreatedBy")
  creditPaymentsCreated SupplierCreditPayment[] @relation("CreditPaymentCreatedBy")

  deletedAt  DateTime? @map("deleted_at")
  @@index([email])
  @@index([roleId])
  @@map("users")
}

// ============================================================
// PROYECTOS
// ============================================================
model Project {
  id              String        @id @default(uuid()) @db.Uuid
  code            String        @unique @db.VarChar(30) // ej. PROJ-2026-001
  name            String        @db.VarChar(200)
  client          String?       @db.VarChar(200)
  location        String?       @db.VarChar(300)
  startDate       DateTime      @map("start_date") @db.Date
  endDate         DateTime?     @map("end_date") @db.Date
  status          ProjectStatus @default(ACTIVE)
  estimatedBudget Decimal       @default(0) @map("estimated_budget") @db.Decimal(15, 2)
  notes           String?       @db.Text
  createdById     String        @map("created_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  createdBy          User                @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  expenses           Expense[]
  items              ProjectItem[]
  addendums          ProjectAddendum[]
  cubicaciones       ProjectCubicacion[]
  anticipos          ProjectAnticipo[]
  assignments        ProjectAssignment[]
  payrolls           Payroll[]
  quotations         Quotation[]
  paymentOrders      PaymentOrder[]
  batches            Batch[]
  contratosAjustados    ContratoAjustado[]              @relation("ProjectContratosAjustados")
  categoryBudgets       ProjectCategoryBudget[]
  batchesEnabled        Boolean                         @default(false) @map("batches_enabled")
  extraordinaryExpenses ProjectExtraordinaryExpense[]

  deletedAt  DateTime? @map("deleted_at")
  @@index([code])
  @@index([status])
  @@map("projects")
}

// ============================================================
// ASIGNACIONES DE PROYECTO (operadores autorizados)
// Admin/Supervisor asigna qué operadores pueden trabajar en un proyecto
// ============================================================
model ProjectAssignment {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid // operador asignado
  assignedById String   @map("assigned_by") @db.Uuid // quien asignó
  createdAt    DateTime @default(now()) @map("created_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User    @relation("AssignedToProject", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User    @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@map("project_assignments")
}

// ============================================================
// ADENDAS DE CONTRATO (incrementos de presupuesto)
// ============================================================
model ProjectAddendum {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  number      Int // Adenda #1, #2, #3... — autoincremental por proyecto
  amount      Decimal  @db.Decimal(15, 2)
  description String   @db.Text
  date        DateTime @db.Date
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("AddendumCreatedBy", fields: [createdById], references: [id])

  @@unique([projectId, number])
  @@index([projectId])
  @@map("project_addendums")
}

// ============================================================
// CUBICACIONES Y AVANCE (cobros al cliente por progreso de obra)
// ============================================================
model ProjectCubicacion {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  number      Int // Cubicación #1, #2, #3... — autoincremental por proyecto
  amount      Decimal  @db.Decimal(15, 2)
  progressPct Decimal  @default(0) @map("progress_pct") @db.Decimal(5, 2) // % avance físico
  description String   @db.Text
  date        DateTime @db.Date
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  ncf         String?  @db.VarChar(19)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("CubicacionCreatedBy", fields: [createdById], references: [id])

  @@unique([projectId, number])
  @@index([projectId])
  @@map("project_cubicaciones")
}

model ProjectAnticipo {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  number      Int
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime @db.Date
  ncf         String?  @db.VarChar(19)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
  @@map("project_anticipos")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED

  @@map("project_status")
}

enum ExtraordinaryExpenseCategory {
  COMISION
  PRESTAMO
  IMPUESTO
  MULTA
  OTRO
}

// ============================================================
// ITEMS DE PROYECTO (partidas/lotes de licitación)
// Identifican qué item del proyecto genera cada gasto/orden
// ============================================================
model ProjectItem {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  number    Int // Item 1, 2, 3... — autoincremental por proyecto
  name      String   @db.VarChar(300)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  paymentOrders PaymentOrder[]
  payrolls      Payroll[]
  quotations    Quotation[]

  @@unique([projectId, number])
  @@index([projectId])
  @@map("project_items")
}

// ============================================================
// TARJETAS CORPORATIVAS
// ============================================================
model CompanyCard {
  id         Int      @id @default(autoincrement())
  holderName String   @map("holder_name") @db.VarChar(150) // Nombre del tarjetahabiente
  lastFour   String   @map("last_four") @db.VarChar(4) // Últimos 4 dígitos
  cardType   String   @map("card_type") @db.VarChar(30) // VISA | MASTERCARD | AMEX | OTHER
  bank       String   @db.VarChar(100) // Banco emisor
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  expenses       Expense[]
  officeExpenses OfficeExpense[]

  @@map("company_cards")
}

// ============================================================
// CATEGORÍAS DE GASTO (dinámicas)
// ============================================================
model ExpenseCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  isSystem    Boolean  @default(false) @map("is_system") // Las 8 categorías base no se eliminan
  createdAt   DateTime @default(now()) @map("created_at")

  expenses        Expense[]
  quotations      Quotation[]
  categoryBudgets ProjectCategoryBudget[]

  @@map("expense_categories")
}

model ProjectCategoryBudget {
  id         String          @id @default(uuid()) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  categoryId Int             @map("category_id")
  budget     Decimal         @db.Decimal(14, 2)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  project  Project         @relation(fields: [projectId], references: [id])
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@unique([projectId, categoryId])
  @@map("project_category_budgets")
}

// ============================================================
// GASTOS
// ============================================================
model Expense {
  id              String        @id @default(uuid()) @db.Uuid
  projectId       String        @map("project_id") @db.Uuid
  categoryId      Int           @map("category_id")
  userId          String        @map("user_id") @db.Uuid
  expenseDate     DateTime      @map("expense_date") @db.Date
  amount          Decimal       @db.Decimal(15, 2)
  description     String        @db.Text
  paymentMethod   PaymentMethod @map("payment_method")
  companyCardId   Int?          @map("company_card_id") // Requerido si paymentMethod = CARD
  hasFiscalDoc    Boolean       @default(false) @map("has_fiscal_doc")
  // Moneda extranjera (opcional)
  foreignAmount   Decimal?      @map("foreign_amount") @db.Decimal(15, 2)
  foreignCurrency String?       @map("foreign_currency") @db.VarChar(10) // USD, EUR, etc.
  exchangeRate    Decimal?      @map("exchange_rate") @db.Decimal(10, 4) // 1 USD = X DOP
  notes           String?       @db.Text
  status          ExpenseStatus @default(PENDING_APPROVAL)
  voidedAt        DateTime?     @map("voided_at")
  voidedById      String?       @map("voided_by") @db.Uuid
  voidReason      String?       @map("void_reason") @db.Text
  rejectionReason String?       @map("rejection_reason") @db.Text
  approvedById    String?       @map("approved_by_id") @db.Uuid
  approvedAt      DateTime?     @map("approved_at")
  rejectedById    String?       @map("rejected_by_id") @db.Uuid
  rejectedAt      DateTime?     @map("rejected_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  project            Project               @relation(fields: [projectId], references: [id])
  category           ExpenseCategory       @relation(fields: [categoryId], references: [id])
  companyCard        CompanyCard?          @relation(fields: [companyCardId], references: [id])
  registeredBy       User                  @relation("ExpenseRegisteredBy", fields: [userId], references: [id])
  voidedBy           User?                 @relation("ExpenseVoidedBy", fields: [voidedById], references: [id])
  approvedBy         User?                 @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  rejectedBy         User?                 @relation("ExpenseRejectedBy", fields: [rejectedById], references: [id])
  batchItemId        String?               @map("batch_item_id") @db.Uuid
  batchItem          BatchItem?            @relation(fields: [batchItemId], references: [id], onDelete: SetNull)
  contratoAjustadoId String?               @map("contrato_ajustado_id") @db.Uuid
  contratoAjustado   ContratoAjustado?     @relation("ExpenseContratoAjustado", fields: [contratoAjustadoId], references: [id], onDelete: SetNull)
  projectItemId      String?               @map("project_item_id") @db.Uuid
  projectItem        ProjectItem?          @relation(fields: [projectItemId], references: [id], onDelete: SetNull)
  fiscalVoucher      FiscalVoucher?
  attachments        Attachment[]
  payrollLine        PayrollLine?          @relation("PayrollLineExpense")
  quotationPayment   QuotationPayment?     @relation("QuotationPaymentExpense")
  quotationLink      QuotationExpenseLink? @relation("QuotationExpenseLink")
  paymentOrder          PaymentOrder?          @relation("PaymentOrderExpense")
  contratoAjustadoPagos ContratoAjustadoPago[] @relation("ContratoAjustadoPagoGasto")
  creditLineId   String?             @map("credit_line_id") @db.Uuid
  creditLine     SupplierCreditLine? @relation("ExpenseCreditLine", fields: [creditLineId], references: [id], onDelete: SetNull)

  deletedAt  DateTime? @map("deleted_at")
  @@index([projectId])
  @@index([expenseDate])
  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([companyCardId])
  @@index([batchItemId])
  @@index([contratoAjustadoId])
  @@index([projectItemId])
  @@index([creditLineId])
  @@map("expenses")
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CHECK
  OTHER

  @@map("payment_method")
}

enum ExpenseStatus {
  PENDING_APPROVAL
  ACTIVE
  VOIDED
  REJECTED

  @@map("expense_status")
}

// ============================================================
// COMPROBANTES FISCALES (DGII — República Dominicana)
// Soporta NCF tradicional (11 chars) y e-NCF electrónico (13 chars)
//
// NCF tradicional:  [A-Z] + 10 dígitos  = 11 chars  ej. B0100000001
// e-NCF electrónico: E    + 12 dígitos  = 13 chars  ej. E310000000001
// ============================================================
model FiscalVoucher {
  id           String   @id @default(uuid()) @db.Uuid
  expenseId    String   @unique @map("expense_id") @db.Uuid
  ncf          String   @db.VarChar(13) // 11 chars NCF | 13 chars e-NCF
  ncfType      String   @map("ncf_type") @db.VarChar(3) // 'B01' o 'E31'
  isElectronic Boolean  @default(false) @map("is_electronic")
  supplierRnc  String   @map("supplier_rnc") @db.VarChar(11)
  supplierName String   @map("supplier_name") @db.VarChar(200)
  itbisAmount  Decimal  @default(0) @map("itbis_amount") @db.Decimal(15, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([ncf])
  @@index([supplierRnc])
  @@map("fiscal_vouchers")
}

// ============================================================
// ADJUNTOS (fotos de facturas, documentos)
// ============================================================
model Attachment {
  id           String   @id @default(uuid()) @db.Uuid
  expenseId    String   @map("expense_id") @db.Uuid
  uploadedById String   @map("uploaded_by") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  filePath     String   @map("file_path") @db.VarChar(500)
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type") @db.VarChar(100)
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  expense    Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@index([expenseId])
  @@map("attachments")
}

// ============================================================
// LOG DE AUDITORÍA
// ============================================================
model AuditLog {
  id        BigInt      @id @default(autoincrement())
  userId    String?     @map("user_id") @db.Uuid
  tableName String      @map("table_name") @db.VarChar(50)
  recordId  String      @map("record_id") @db.VarChar(100)
  action    AuditAction
  oldData   Json?       @map("old_data")
  newData   Json?       @map("new_data")
  ipAddress String?     @map("ip_address") @db.VarChar(45)
  userAgent String?     @map("user_agent") @db.VarChar(500)
  createdAt DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE

  @@map("audit_action")
}

// ============================================================
// INVITACIONES DE USUARIO
// ============================================================
model Invitation {
  id          BigInt    @id @default(autoincrement())
  email       String    @db.VarChar(150)
  roleId      Int       @map("role_id")
  token       String    @unique @db.VarChar(100)
  invitedById String    @map("invited_by") @db.Uuid
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  invitedBy User @relation("InvitedBy", fields: [invitedById], references: [id])
  role      Role @relation(fields: [roleId], references: [id])

  @@index([token])
  @@index([email])
  @@map("invitations")
}

// ============================================================
// NÓMINAS POR PROYECTO
// ============================================================
model Payroll {
  id               String        @id @default(uuid()) @db.Uuid
  projectId        String        @map("project_id") @db.Uuid
  number           Int // NOM-001, NOM-002 — autoincremental por proyecto
  periodStart      DateTime      @map("period_start") @db.Date
  periodEnd        DateTime      @map("period_end") @db.Date
  type             PayrollType   @default(LABOR)
  status           PayrollStatus @default(DRAFT)
  description      String        @db.Text
  totalAmount      Decimal       @default(0) @map("total_amount") @db.Decimal(15, 2)
  notes            String?       @db.Text
  createdById      String        @map("created_by") @db.Uuid
  approvedById     String?       @map("approved_by") @db.Uuid
  approvedAt       DateTime?     @map("approved_at")
  paidAt           DateTime?     @map("paid_at")
  paymentMethod    String?       @map("payment_method") @db.VarChar(20) // CASH | TRANSFER
  paymentDate      DateTime?     @map("payment_date") @db.Date
  paymentBank      String?       @map("payment_bank") @db.VarChar(100) // transferencia
  paymentReference String?       @map("payment_reference") @db.VarChar(100) // transferencia
  receiptNumber    String?       @map("receipt_number") @db.VarChar(50) // efectivo
  receivedBy       String?       @map("received_by") @db.VarChar(100) // efectivo
  voidedAt         DateTime?     @map("voided_at")
  voidedById       String?       @map("voided_by") @db.Uuid
  voidReason       String?       @map("void_reason") @db.Text
  projectItemId    String?       @map("project_item_id") @db.Uuid
  batchItemId      String?       @map("batch_item_id") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  project      Project       @relation(fields: [projectId], references: [id])
  projectItem  ProjectItem?  @relation(fields: [projectItemId], references: [id], onDelete: SetNull)
  batchItem    BatchItem?    @relation("PayrollBatchItem", fields: [batchItemId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("PayrollCreatedBy", fields: [createdById], references: [id])
  approvedBy   User?         @relation("PayrollApprovedBy", fields: [approvedById], references: [id])
  voidedBy     User?         @relation("PayrollVoidedBy", fields: [voidedById], references: [id])
  paymentOrder          PaymentOrder?
  lines                 PayrollLine[]
  contratoAjustadoPagos ContratoAjustadoPago[] @relation("ContratoAjustadoPagoNomina")

  deletedAt  DateTime? @map("deleted_at")
  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([periodStart])
  @@index([projectItemId])
  @@index([batchItemId])
  @@map("payrolls")
}

model PayrollLine {
  id                 String    @id @default(uuid()) @db.Uuid
  payrollId          String    @map("payroll_id") @db.Uuid
  lineNumber         Int       @map("line_number")
  description        String    @db.VarChar(300)
  quantity           Decimal   @db.Decimal(10, 3)
  unit               String    @db.VarChar(30) // Hrs, Días, Glb, m², etc.
  unitPrice          Decimal   @map("unit_price") @db.Decimal(15, 2)
  subtotal           Decimal   @db.Decimal(15, 2) // quantity * unitPrice (computed, stored)
  notes              String?   @db.VarChar(300)
  supplierName       String?   @map("supplier_name") @db.VarChar(200) // Nombre del suplidor / trabajador
  bankName           String?   @map("bank_name") @db.VarChar(100) // Banco receptor del beneficiario
  bankAccount        String?   @map("bank_account") @db.VarChar(100) // Cuenta del beneficiario
  // Comprobante de pago individual
  paymentBank        String?   @map("payment_bank") @db.VarChar(100) // Banco desde donde se transfirió
  paymentReference   String?   @map("payment_reference") @db.VarChar(100) // No. de transacción / comprobante
  paidAt             DateTime? @map("paid_at") // Fecha de la transferencia
  contratoAjustadoId String?   @map("contrato_ajustado_id") @db.Uuid
  expenseId          String?   @unique @map("expense_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  payroll          Payroll           @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  contratoAjustado ContratoAjustado? @relation("PayrollLineContratoAjustado", fields: [contratoAjustadoId], references: [id], onDelete: SetNull)
  expense          Expense?          @relation("PayrollLineExpense", fields: [expenseId], references: [id], onDelete: SetNull)

  @@unique([payrollId, lineNumber])
  @@index([payrollId])
  @@index([contratoAjustadoId])
  @@index([expenseId])
  @@map("payroll_lines")
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  VOIDED

  @@map("payroll_status")
}

enum PayrollType {
  LABOR // Mano de obra
  SERVICE // Servicios contratados

  @@map("payroll_type")
}

// ============================================================
// MONITOREO DEL SISTEMA
// ============================================================
model SystemLog {
  id         String   @id @default(uuid()) @db.Uuid
  level      String   @db.VarChar(10) // error | warn | info
  category   String   @db.VarChar(50) // api | database | auth | cron | system
  message    String   @db.Text
  details    Json? // stack trace, request body, etc.
  userId     String?  @map("user_id") @db.Uuid
  endpoint   String?  @db.VarChar(200)
  method     String?  @db.VarChar(10)
  statusCode Int?     @map("status_code")
  duration   Int? // ms
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([level])
  @@index([category])
  @@index([createdAt])
  @@map("system_logs")
}

model HealthCheckResult {
  id            String   @id @default(uuid()) @db.Uuid
  status        String   @db.VarChar(20) // healthy | degraded | unhealthy
  dbOk          Boolean  @map("db_ok")
  memoryUsedPct Float    @map("memory_used_pct")
  uptimeSeconds Float    @map("uptime_seconds")
  responseTime  Int      @map("response_time") // ms
  details       Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("health_check_results")
}

// ============================================================
// REFRESH TOKENS
// ============================================================
model RefreshToken {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// COTIZACIONES Y ANTICIPOS
// ============================================================

enum QuotationStatus {
  PENDING // Cotización recibida, pendiente de aprobación
  APPROVED // Aprobada para proceder
  ADVANCE_PAID // Al menos un anticipo pagado
  IN_PROGRESS // En ejecución / fabricación
  PARTIAL_INVOICED // Factura parcial recibida
  INVOICED // Factura completa recibida
  PAID // Pagada completamente
  CANCELLED // Cancelada

  @@map("quotation_status")
}

enum QuotationLinkType {
  ADVANCE // Anticipo (pago previo a factura)
  PARTIAL_INVOICE // Factura parcial
  FINAL_INVOICE // Factura final
  COMPLEMENTARY // Gasto complementario relacionado

  @@map("quotation_link_type")
}

model Quotation {
  id         String @id @default(uuid()) @db.Uuid
  projectId  String @map("project_id") @db.Uuid
  number     Int // COTI-001 por proyecto — autoincremental
  categoryId Int?   @map("category_id")

  // Datos del suplidor
  supplierId   String? @map("supplier_id") @db.Uuid
  supplierName String  @map("supplier_name") @db.VarChar(200)
  supplierRnc  String? @map("supplier_rnc") @db.VarChar(11)

  // Datos del documento
  quotationNumber String?   @map("quotation_number") @db.VarChar(50)
  quotationDate   DateTime  @map("quotation_date") @db.Date
  validUntil      DateTime? @map("valid_until") @db.Date

  // Montos
  currency    String  @default("DOP") @db.VarChar(3)
  subtotal    Decimal @db.Decimal(15, 2)
  itbisAmount Decimal @default(0) @map("itbis_amount") @db.Decimal(15, 2)
  total       Decimal @db.Decimal(15, 2)

  // Condiciones comerciales
  description  String   @db.Text
  paymentTerms String?  @map("payment_terms") @db.Text
  advancePct   Decimal? @map("advance_pct") @db.Decimal(5, 2)
  deliveryDays Int?     @map("delivery_days")
  observations String?  @db.Text

  // Estado y trazabilidad
  status        QuotationStatus @default(PENDING)
  notes         String?         @db.Text
  projectItemId String?         @map("project_item_id") @db.Uuid
  batchItemId   String?         @map("batch_item_id") @db.Uuid
  createdById   String          @map("created_by") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  project      Project                @relation(fields: [projectId], references: [id])
  supplier     Supplier?              @relation("QuotationSupplier", fields: [supplierId], references: [id], onDelete: SetNull)
  projectItem  ProjectItem?           @relation(fields: [projectItemId], references: [id], onDelete: SetNull)
  batchItem    BatchItem?             @relation("QuotationBatchItem", fields: [batchItemId], references: [id], onDelete: SetNull)
  category     ExpenseCategory?       @relation(fields: [categoryId], references: [id])
  createdBy    User                   @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  payments      QuotationPayment[]
  expenseLinks  QuotationExpenseLink[]
  attachments   QuotationAttachment[]
  paymentOrders PaymentOrder[]         @relation("PaymentOrderQuotation")

  deletedAt  DateTime? @map("deleted_at")
  @@unique([projectId, number])
  @@index([projectId])
  @@index([supplierId])
  @@index([status])
  @@index([supplierName])
  @@index([projectItemId])
  @@index([batchItemId])
  @@map("quotations")
}

// Anticipos y pagos parciales vinculados a una cotización
model QuotationPayment {
  id            String        @id @default(uuid()) @db.Uuid
  quotationId   String        @map("quotation_id") @db.Uuid
  expenseId     String?       @unique @map("expense_id") @db.Uuid
  sequence      Int
  amount        Decimal       @db.Decimal(15, 2)
  paymentDate   DateTime      @map("payment_date") @db.Date
  paymentMethod PaymentMethod
  description   String        @db.VarChar(300)
  notes         String?       @db.Text
  createdById   String        @map("created_by") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  expense   Expense?  @relation("QuotationPaymentExpense", fields: [expenseId], references: [id])
  createdBy User      @relation("QuotationPaymentCreatedBy", fields: [createdById], references: [id])

  @@unique([quotationId, sequence])
  @@index([quotationId])
  @@index([expenseId])
  @@map("quotation_payments")
}

// Vínculo de conciliación: cotización <-> gasto/factura final
model QuotationExpenseLink {
  id          String            @id @default(uuid()) @db.Uuid
  quotationId String            @map("quotation_id") @db.Uuid
  expenseId   String            @unique @map("expense_id") @db.Uuid
  linkType    QuotationLinkType
  notes       String?           @db.Text
  createdById String            @map("created_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  expense   Expense   @relation("QuotationExpenseLink", fields: [expenseId], references: [id])
  createdBy User      @relation("QuotationLinkCreatedBy", fields: [createdById], references: [id])

  @@index([quotationId])
  @@map("quotation_expense_links")
}

// ============================================================
// DIRECTORIO DE SUPLIDORES (también actúan como beneficiarios de pagos)
// ============================================================
model Supplier {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(200)
  rnc           String?  @unique @db.VarChar(11)
  cedula        String?  @db.VarChar(20)
  phone         String?  @db.VarChar(20)
  email         String?  @db.VarChar(150)
  address       String?  @db.Text
  notes         String?  @db.Text
  // Datos bancarios (opcionales — solo si recibe pagos directos)
  bank          String?  @db.VarChar(100)
  accountType   String?  @map("account_type") @db.VarChar(30) // Cuenta de Ahorros | Cuenta Corriente | Cuenta Nómina
  accountNumber String?  @map("account_number") @db.VarChar(50)
  isActive      Boolean  @default(true) @map("is_active")
  createdById   String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  createdBy          User                  @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  contratosAjustados ContratoAjustado[]     @relation("SupplierContratosAjustados")
  paymentOrders      PaymentOrder[]
  bankAccounts       SupplierBankAccount[]
  quotations         Quotation[]            @relation("QuotationSupplier")
  creditLines        SupplierCreditLine[]

  deletedAt  DateTime? @map("deleted_at")
  @@index([name])
  @@index([rnc])
  @@index([isActive])
  @@map("suppliers")
}

model SupplierBankAccount {
  id            String   @id @default(uuid()) @db.Uuid
  supplierId    String   @map("supplier_id") @db.Uuid
  bank          String   @db.VarChar(100)
  accountType   String   @default("Cuenta de Ahorros") @map("account_type") @db.VarChar(30)
  accountNumber String   @map("account_number") @db.VarChar(50)
  currency      String   @default("RD$") @db.VarChar(5)
  isDefault     Boolean  @default(false) @map("is_default")
  notes         String?  @db.VarChar(200)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_bank_accounts")
}

model SupplierCreditLine {
  id           String   @id @default(uuid()) @db.Uuid
  supplierId   String   @map("supplier_id") @db.Uuid
  creditLimit  Decimal  @map("credit_limit") @db.Decimal(15, 2)
  notes        String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  supplier      Supplier               @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy     User                   @relation("CreditLineCreatedBy", fields: [createdById], references: [id])
  expenses      Expense[]              @relation("ExpenseCreditLine")
  payments      SupplierCreditPayment[]
  paymentOrders PaymentOrder[]         @relation("PaymentOrderCreditLine")

  deletedAt  DateTime? @map("deleted_at")
  @@index([supplierId])
  @@map("supplier_credit_lines")
}

model SupplierCreditPayment {
  id            String        @id @default(uuid()) @db.Uuid
  creditLineId  String        @map("credit_line_id") @db.Uuid
  amount        Decimal       @db.Decimal(15, 2)
  paymentDate   DateTime      @map("payment_date") @db.Date
  paymentMethod PaymentMethod @map("payment_method")
  reference     String?       @db.VarChar(100)
  notes         String?       @db.Text
  createdById   String        @map("created_by") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")

  creditLine SupplierCreditLine @relation(fields: [creditLineId], references: [id], onDelete: Cascade)
  createdBy  User               @relation("CreditPaymentCreatedBy", fields: [createdById], references: [id])

  @@index([creditLineId])
  @@map("supplier_credit_payments")
}

// ============================================================
// ÓRDENES DE PAGO
// ============================================================
model PaymentOrder {
  id            String    @id @default(uuid()) @db.Uuid
  number        Int // Autoincremental por aplicación
  orderType     String    @default("SERVICIO") @map("order_type") @db.VarChar(20) // SERVICIO | PAYROLL | MATERIALS
  payingCompany String    @map("paying_company") @db.VarChar(200)
  supplierId    String    @map("supplier_id") @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  amount        Decimal   @db.Decimal(15, 2)
  currency      String    @default("RD$") @db.VarChar(10)
  concept       String    @db.Text
  status        String    @default("PENDING") @db.VarChar(20) // PENDING | PAID | VOIDED
  generatedText String?   @map("generated_text") @db.Text
  notes         String?   @db.VarChar(500)
  paidAt            DateTime? @map("paid_at")
  paidById          String?   @map("paid_by_id") @db.Uuid
  paymentBank       String?   @map("payment_bank")      @db.VarChar(100) // Banco emisor
  paymentReference  String?   @map("payment_reference") @db.VarChar(100) // No. de transacción
  paymentMethod             PaymentMethod? @map("payment_method")
  exchangeRate              Decimal?       @map("exchange_rate")              @db.Decimal(10, 4)
  exchangeRateValidatedBy   String?        @map("exchange_rate_validated_by") @db.Uuid
  exchangeRateValidatedAt   DateTime?      @map("exchange_rate_validated_at")
  // Vínculos opcionales
  payrollId          String?   @unique @map("payroll_id") @db.Uuid
  expenseId          String?   @unique @map("expense_id") @db.Uuid
  contratoAjustadoId String?   @map("contrato_ajustado_id") @db.Uuid
  quotationId        String?   @map("quotation_id") @db.Uuid
  projectItemId      String?   @map("project_item_id") @db.Uuid
  batchItemId        String?   @map("batch_item_id") @db.Uuid
  creditLineId       String?   @map("credit_line_id") @db.Uuid
  createdById        String    @map("created_by_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  project          Project           @relation(fields: [projectId], references: [id])
  createdBy        User              @relation("PaymentOrderCreatedBy", fields: [createdById], references: [id])
  paidBy           User?             @relation("PaymentOrderPaidBy", fields: [paidById], references: [id])
  exchangeRateValidator     User?          @relation("PaymentOrderExchangeValidatedBy", fields: [exchangeRateValidatedBy], references: [id])
  payroll          Payroll?          @relation(fields: [payrollId], references: [id])
  expense          Expense?          @relation("PaymentOrderExpense", fields: [expenseId], references: [id])
  contratoAjustado          ContratoAjustado?      @relation("PaymentOrderContratoAjustado", fields: [contratoAjustadoId], references: [id], onDelete: SetNull)
  quotation                 Quotation?             @relation("PaymentOrderQuotation", fields: [quotationId], references: [id], onDelete: SetNull)
  projectItem               ProjectItem?           @relation(fields: [projectItemId], references: [id], onDelete: SetNull)
  batchItem                 BatchItem?             @relation("PaymentOrderBatchItem", fields: [batchItemId], references: [id], onDelete: SetNull)
  creditLine                SupplierCreditLine?    @relation("PaymentOrderCreditLine", fields: [creditLineId], references: [id], onDelete: SetNull)
  contratoAjustadoPagos     ContratoAjustadoPago[] @relation("ContratoAjustadoPagoOrdenPago")

  deletedAt  DateTime? @map("deleted_at")
  @@index([status])
  @@index([projectId])
  @@index([supplierId])
  @@index([contratoAjustadoId])
  @@index([quotationId])
  @@index([projectItemId])
  @@index([batchItemId])
  @@index([creditLineId])
  @@index([createdAt])
  @@map("payment_orders")
}

// ============================================================
// GASTOS DE OFICINA (independiente de proyectos)
// ============================================================
model OfficeExpense {
  id            String                @id @default(uuid()) @db.Uuid
  category      OfficeExpenseCategory
  description   String                @db.VarChar(500)
  amount        Decimal               @db.Decimal(12, 2)
  itbisAmount   Decimal               @default(0) @map("itbis_amount") @db.Decimal(12, 2)
  expenseDate   DateTime              @map("expense_date") @db.Date
  paymentMethod PaymentMethod         @map("payment_method")
  companyCardId Int?                  @map("company_card_id")
  supplierName  String?               @map("supplier_name") @db.VarChar(200)
  hasFiscalDoc  Boolean               @default(false) @map("has_fiscal_doc")
  fiscalDocNum  String?               @map("fiscal_doc_num") @db.VarChar(50)
  notes         String?               @db.Text
  receiptUrl    String?               @map("receipt_url") @db.VarChar(500)
  status        OfficeExpenseStatus   @default(ACTIVE)
  createdById   String                @map("created_by") @db.Uuid
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  createdBy   User         @relation("OfficeExpenseCreatedBy", fields: [createdById], references: [id])
  companyCard CompanyCard? @relation(fields: [companyCardId], references: [id])

  deletedAt  DateTime? @map("deleted_at")
  @@index([category])
  @@index([expenseDate])
  @@index([createdAt])
  @@map("office_expenses")
}

enum OfficeExpenseCategory {
  CLEANING_SUPPLIES
  CONSUMABLES
  OFFICE_SERVICES
  BIDDING
  OFFICE_ASSETS
  OTHER

  @@map("office_expense_category")
}

enum OfficeExpenseStatus {
  ACTIVE
  VOIDED

  @@map("office_expense_status")
}

// Adjuntos de cotizaciones (separado de Attachment para no tocar estructura existente)
model QuotationAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  quotationId  String   @map("quotation_id") @db.Uuid
  uploadedById String   @map("uploaded_by") @db.Uuid
  fileName     String   @map("file_name") @db.VarChar(255)
  filePath     String   @map("file_path") @db.VarChar(500)
  fileSize     Int      @map("file_size")
  mimeType     String   @map("mime_type") @db.VarChar(100)
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  quotation  Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation(fields: [uploadedById], references: [id])

  @@index([quotationId])
  @@map("quotation_attachments")
}

// ============================================================
// LOTES/LICITACIONES (para agrupar gastos por licitación)
// ============================================================
model Batch {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  code        String   @db.VarChar(50)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  totalBudget Decimal  @default(0) @map("total_budget") @db.Decimal(15, 2)
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   BatchItem[]

  deletedAt  DateTime? @map("deleted_at")
  @@unique([projectId, code])
  @@index([projectId])
  @@map("batches")
}

model BatchItem {
  id          String   @id @default(uuid()) @db.Uuid
  batchId     String   @map("batch_id") @db.Uuid
  code        String   @db.VarChar(50)
  description String   @db.Text
  provincia   String   @db.VarChar(100)
  sector      String   @db.VarChar(200)
  budget      Decimal  @default(0) @db.Decimal(15, 2)
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  batch    Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  paymentOrders PaymentOrder[] @relation("PaymentOrderBatchItem")
  payrolls      Payroll[]      @relation("PayrollBatchItem")
  quotations    Quotation[]    @relation("QuotationBatchItem")

  @@unique([batchId, code])
  @@index([batchId])
  @@map("batch_items")
}

// ============================================================
// NOTIFICACIONES IN-APP
// ============================================================
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50) // BUDGET_80 | BUDGET_90 | PENDING_ORDERS | PAYROLL_UNPAID
  title     String   @db.VarChar(200)
  message   String   @db.Text
  link      String?  @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  entityId  String?  @map("entity_id") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([type, entityId])
  @@map("notifications")
}

// ============================================================
// CONTACTOS DE NOTIFICACIÓN (externos, no requieren cuenta)
// ============================================================
model NotificationContact {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  phone       String?  @db.VarChar(30) // formato +18091234567
  email       String?  @db.VarChar(150)
  isActive    Boolean  @default(true) @map("is_active")
  notifTypes  String[] @default([]) @map("notif_types")
  createdById String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User @relation("ContactCreatedBy", fields: [createdById], references: [id])

  @@index([isActive])
  @@map("notification_contacts")
}

// ============================================================
// CONTRATOS AJUSTADOS (mano de obra por monto pactado)
// ============================================================
model ContratoAjustado {
  id                 String                 @id @default(uuid()) @db.Uuid
  projectId          String                 @map("project_id") @db.Uuid
  supplierId         String                 @map("supplier_id") @db.Uuid
  descripcionTrabajo String                 @map("descripcion_trabajo") @db.Text
  montoContratado    Decimal                @map("monto_contratado") @db.Decimal(15, 2)
  fechaContrato      DateTime               @map("fecha_contrato") @db.Date
  estado             ContratoAjustadoEstado @default(ACTIVO)
  observaciones      String?                @db.Text
  createdById        String                 @map("created_by") @db.Uuid
  updatedById        String?                @map("updated_by") @db.Uuid
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  project      Project                @relation("ProjectContratosAjustados", fields: [projectId], references: [id])
  supplier     Supplier               @relation("SupplierContratosAjustados", fields: [supplierId], references: [id])
  createdBy    User                   @relation("ContratoAjustadoCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?                  @relation("ContratoAjustadoUpdatedBy", fields: [updatedById], references: [id])
  pagos         ContratoAjustadoPago[]
  adendas       ContratoAjustadoAdenda[]
  expenses      Expense[]              @relation("ExpenseContratoAjustado")
  payrollLines  PayrollLine[]          @relation("PayrollLineContratoAjustado")
  paymentOrders PaymentOrder[]         @relation("PaymentOrderContratoAjustado")

  deletedAt  DateTime? @map("deleted_at")
  @@index([projectId])
  @@index([supplierId])
  @@index([estado])
  @@map("contratos_ajustados")
}

model ContratoAjustadoAdenda {
  id                 String   @id @default(uuid()) @db.Uuid
  contratoAjustadoId String   @map("contrato_ajustado_id") @db.Uuid
  number             Int
  monto              Decimal  @db.Decimal(15, 2)
  descripcion        String   @db.VarChar(500)
  fecha              DateTime @db.Date
  createdById        String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  contratoAjustado ContratoAjustado @relation(fields: [contratoAjustadoId], references: [id], onDelete: Cascade)
  createdBy        User             @relation("ContratoAdendaCreatedBy", fields: [createdById], references: [id])

  @@unique([contratoAjustadoId, number])
  @@index([contratoAjustadoId])
  @@map("contrato_ajustado_adendas")
}

model ContratoAjustadoPago {
  id                 String   @id @default(uuid()) @db.Uuid
  contratoAjustadoId String   @map("contrato_ajustado_id") @db.Uuid
  ordenPagoId        String?  @map("orden_pago_id") @db.Uuid
  nominaId           String?  @map("nomina_id") @db.Uuid
  gastoId            String?  @map("gasto_id") @db.Uuid
  monto              Decimal  @db.Decimal(15, 2)
  fecha              DateTime @db.Date
  creadoPorId        String   @map("creado_por") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  contratoAjustado ContratoAjustado @relation(fields: [contratoAjustadoId], references: [id], onDelete: Cascade)
  ordenPago        PaymentOrder?    @relation("ContratoAjustadoPagoOrdenPago", fields: [ordenPagoId], references: [id], onDelete: SetNull)
  nomina           Payroll?         @relation("ContratoAjustadoPagoNomina",    fields: [nominaId],    references: [id], onDelete: SetNull)
  gasto            Expense?         @relation("ContratoAjustadoPagoGasto",     fields: [gastoId],     references: [id], onDelete: SetNull)
  creadoPor        User             @relation("ContratoAjustadoPagoCreadoPor", fields: [creadoPorId], references: [id])

  @@index([contratoAjustadoId])
  @@index([gastoId])
  @@index([ordenPagoId])
  @@index([nominaId])
  @@index([creadoPorId])
  @@map("contrato_ajustado_pagos")
}

enum ContratoAjustadoEstado {
  ACTIVO
  COMPLETADO
  CANCELADO

  @@map("contrato_ajustado_estado")
}

// ============================================================
// OCR JOBS (procesamiento asíncrono de documentos)
// ============================================================
model OcrJob {
  id          String    @id @default(uuid()) @db.Uuid
  status      String    @default("processing") @db.VarChar(20) // "processing" | "completed" | "failed"
  result      Json?
  error       String?   @db.Text
  userId      String    @map("user_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("ocr_jobs")
}

// ============================================================
// SUSCRIPCIONES DE SERVICIOS (Render, GitHub, Twilio, etc.)
// ============================================================
model ServiceSubscription {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  provider      String
  description   String?
  monthlyCost   Decimal  @map("monthly_cost") @db.Decimal(10, 2)
  currency      String   @default("USD")
  billingDay    Int      @map("billing_day")
  paymentMethod String?  @map("payment_method")
  url           String?
  isActive      Boolean  @default(true) @map("is_active")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("service_subscriptions")
}

// ── WhatsApp Integration ───────────────────────────────────────

model WhatsAppConversation {
  id          String   @id @default(uuid()) @db.Uuid
  phoneNumber String   @db.VarChar(30) @map("phone_number")
  userId      String?  @map("user_id") @db.Uuid
  status      String   @default("ACTIVE") @db.VarChar(20)
  contextData Json     @default("{}") @map("context_data")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User?             @relation("WhatsAppConversationUser", fields: [userId], references: [id], onDelete: SetNull)
  messages WhatsAppMessage[]

  @@unique([phoneNumber])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  direction      String   @db.VarChar(10)
  content        String   @db.Text
  aiIntent       String?  @map("ai_intent") @db.VarChar(50)
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("whatsapp_messages")
}

model WhatsAppAuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  action          String   @db.VarChar(50)
  entityType      String?  @map("entity_type") @db.VarChar(50)
  entityId        String?  @map("entity_id") @db.VarChar(100)
  requestPayload  Json     @map("request_payload")
  responsePayload Json     @map("response_payload")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("whatsapp_audit_logs")
}

// ============================================================
// GASTOS EXTRAORDINARIOS DE PROYECTO
// ============================================================
model ProjectExtraordinaryExpense {
  id          String                       @id @default(cuid())
  projectId   String
  project     Project                      @relation(fields: [projectId], references: [id])
  description String
  amount      Decimal                      @db.Decimal(15, 2)
  date        DateTime                     @db.Date
  category    ExtraordinaryExpenseCategory
  notes       String?
  createdBy   String
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([projectId])
  @@map("project_extraordinary_expenses")
}
